# Copy this file to .env in the repo root and fill in real values.
# Never commit the real .env — it's git-ignored, and this .env.example must only ever contain
# placeholders (see LAUNCH_READINESS_CHECKLIST.md §1 "Secrets hygiene").

DATABASE_URL=mysql://user:password@host:3306/PlanetOneDashboard
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3307
DB_NAME=PlanetOneDashboard
DB_USER=root
DB_PASSWORD=change_me
DB_ROOT_PASSWORD=change_me
PORT=5000
JWT_SECRET=replace_with_a_long_random_string

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=
DEFAULT_FROM_EMAIL=
ADMIN_EMAIL=
EMAIL_HOST_PASSWORD=

# Optional - DB backup schedule overrides (see backend/services/backupService.js)
# DB_BACKUP_DIR=
# DB_BACKUP_S3_PREFIX=
# DB_BACKUP_RETENTION_COUNT=
